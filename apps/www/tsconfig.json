{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2023", "dom", "dom.iterable"],
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@acme/ui/*": ["../../@acme/ui/src/*"],
      "@/lib/*": ["../../@acme/ui/src/lib/*"],
      "@/hooks/*": ["../../@acme/hooks/src/*"],
      "@/components/ui": ["../../@acme/ui/src/components/index.ts"],
      "@/components/ui/*": ["../../@acme/ui/src/components/*"],
      "@/components/icons": ["../../@acme/ui/src/icons/index.ts"],
      "@/components/*": ["../../@acme/ui/src/icons/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "module": "esnext",
    "strictNullChecks": true
  },
  "include": [".", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "../../@acme/ui/src/shadcn/calendar.tsx"]
}
