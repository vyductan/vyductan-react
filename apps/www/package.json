{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "www",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:generate": "dotenv -e ../../.env -- pnpx @better-auth/cli generate --output ./api/auth/schema.ts",
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "db:import:notion-words": "pnpm with-env jiti scripts/import-notion-to-supabase.ts",
    "db:push": "pnpm with-env drizzle-kit push",
    "db:seed:habits": "pnpm with-env jiti src/scripts/seed-habits.ts",
    "db:status": "pnpm with-env drizzle-kit check",
    "dev": "pnpm with-env next dev --port 4000",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "prettier": "@acme/prettier-config",
  "dependencies": {
    "@acme/ui": "workspace:*",
    "@ant-design/colors": "^8.0.0",
    "@hookform/resolvers": "catalog:",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/bundle-analyzer": "^16.2.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "dayjs": "catalog:",
    "lucide-react": "catalog:",
    "next": "^16.2.1",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "sharp": "^0.34.5",
    "zod": "catalog:  ",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@next/mdx": "^16.2.1",
    "@types/lodash": "catalog:",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:",
    "@types/nodemailer": "^7.0.4",
    "@types/nprogress": "^0.2.3",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@types/react-scroll": "^1.8.10",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "catalog:",
    "jiti": "^2.6.1",
    "postcss-replace": "^2.0.1",
    "prettier": "catalog:",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
