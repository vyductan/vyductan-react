{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./.cache/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "paths": {
      "~/*": ["./src/*"],
      "@acme/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"]
}
