{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "allowImportingTsExtensions": true,
    "paths": {
      "~/*": ["./src/*"],
      "@acme/ui/*": ["../../@acme/ui/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "references": []
}
